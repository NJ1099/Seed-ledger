# Seed Ledger — 환경변수 예제
# ─────────────────────────────────────────────────
# 이 파일은 git 에 커밋되는 템플릿입니다.
# 실제 값을 채워서 사용하려면 이 파일을 복사해 ".env" 로 저장하세요:
#
#   Windows:  copy .env.example .env
#   macOS/Linux:  cp .env.example .env
#
# 그리고 ".env" 안의 각 KEY=VALUE 줄에 본인 키를 입력합니다.
# 서버는 부팅 시 .env 를 자동 로드합니다 (zero-deps, 내장 파서).
#
# 주의: .env 는 .gitignore 에 등록되어 있어 GitHub 에 올라가지 않습니다.
#       Render 같은 호스팅에서는 이 파일 대신 대시보드의 "Environment Variables"
#       메뉴에서 동일한 KEY=VALUE 를 등록하세요.
# ─────────────────────────────────────────────────

# ── 네이버 OpenAPI (뉴스 검색에 사용) ─────────────────────
# 발급: https://developers.naver.com/apps/#/register
#   → 애플리케이션 등록 → "검색" 사용 API 체크
#   → Client ID / Client Secret 복사해서 아래에 붙여넣기
# 미입력 시 /api/stock-news 는 기존 stock.naver.com 헤드라인 폴백 사용.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── DART OpenAPI (국민연금 매수/매도 표에 사용) ──────────
# 발급: https://opendart.fss.or.kr/uss/umt/cmm/EgovMberRegist.do
#   → 회원가입 → 인증키 신청 (즉시 발급, 40자)
# 일일 1만 호출 무료. 미입력 시 /api/pension-flows 비활성.
DART_API_KEY=

# ── 공공데이터포털 (data.go.kr) — 국민연금공단 기금 포트폴리오 ─
# 발급: https://www.data.go.kr → 로그인 → 활용신청 → 인증키 확인
# 일반적으로 'Encoding' 키 (URL-safe) 사용. 키 형식: 영숫자 + %2B, %2F 등 100자 안팎.
# 데이터셋 예: https://www.data.go.kr/data/15106894/fileData.do (기금 포트폴리오 현황)
# 미입력 시 해당 데이터 비활성. 다음 라운드에서 활용 예정.
DATA_GO_KR_SERVICE_KEY=

# ── KRX 정보데이터시스템 로그인 (연기금 일별 매매 조회) ──────
# 2025-12-27 이후 KRX 가 로그인을 필수화 → data.krx.co.kr 회원 ID/PW 필요.
# 가입: https://data.krx.co.kr → 우상단 회원가입 (무료).
# 미입력 시 비인증 세션으로만 진행 → 로그인 필요 데이터는 조회 불가.
# 주의: 일반 KRX 웹사이트 비밀번호. 채팅/커밋에 노출 금지, .env 에만 입력.
KRX_ID=
KRX_PW=

# ── Anthropic Claude API (뉴스 AI 요약 — 선택, 향후 라운드용) ──
# 발급: https://console.anthropic.com/settings/keys
# 미입력 시 AI 요약 기능 비활성.
ANTHROPIC_API_KEY=

# ── 텔레그램 봇 (기기 간 동기화 — 라운드 2 에서 도입, 선택) ──
# 발급: @BotFather 봇과 대화 → /newbot → 토큰 발급
# 미입력 시 동기화 모달이 "비활성" 상태로 표시.
TELEGRAM_BOT_TOKEN=

# ── 일일 주식 뉴스 푸시 (매일 09:30 / 18:00 KST) ─────────
# 뉴스 발송 전용 봇 토큰. 위 TELEGRAM_BOT_TOKEN(동기화용 봇)과 다른 봇을
# 쓰고 싶을 때 여기에 별도 토큰을 넣는다. 미입력 시 TELEGRAM_BOT_TOKEN 으로
# 폴백한다(같은 봇으로 동기화+뉴스 둘 다 처리).
TELEGRAM_NEWS_BOT_TOKEN=

# 매일 09:30 / 18:00 (KST) 에 최신 주식 뉴스 10건을 발송할 텔레그램 채팅방 ID.
# 채팅방 ID 확인: 위 뉴스 봇을 대화방/그룹에 추가한 뒤
#   https://api.telegram.org/bot<뉴스봇토큰>/getUpdates 의 chat.id 값.
# 개인 채팅은 양수, 그룹/채널은 보통 음수(-100...). 미입력 시 뉴스 푸시 비활성.
# 주의: 봇을 발송 대상 채널에는 관리자(게시 권한), 그룹에는 멤버로 추가해야 함.
TELEGRAM_NEWS_CHAT_ID=

# ── 공지(notice) 관리자 토큰 ────────────────────────────
# 공지 작성/수정/삭제 권한용 비밀 토큰. 사이트에서 "관리자" 로그인 시 입력하면
# 브라우저에 저장되고, 쓰기 요청에 Authorization: Bearer 로 전송된다.
# 충분히 긴 임의 문자열로 설정(예: openssl rand -hex 24). 미설정 시 공지 쓰기 비활성(읽기만).
ADMIN_TOKEN=

# ── 공지 영속 저장 (Upstash Redis REST) ─────────────────
# Render Free 는 디스크가 휘발성이라 공지를 서버 파일에 저장하면 재배포/sleep 시 사라진다.
# Upstash(무료) Redis 를 만들어 REST URL/TOKEN 을 등록하면 영속 보존된다.
# 발급: https://console.upstash.com → Redis DB 생성 → REST API 의 URL/TOKEN 복사.
# 미설정 시 data/notices.json 파일로 폴백(로컬에서만 영속).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── 사이트 주소 (뉴스 메시지 하단 링크) ─────────────────
# 뉴스 텔레그램 메시지 하단에 붙는 링크. 기본값 https://seed-ledger.onrender.com
# PUBLIC_SITE_URL=https://seed-ledger.onrender.com

# ── 로컬 포트 (선택) ────────────────────────────────────
# 명시하지 않으면 4274, Render 환경에서는 PORT 자동 주입.
# PORT=4274
