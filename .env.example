# Seed Ledger — 환경변수 예제
# ─────────────────────────────────────────────────
# 이 파일은 git 에 커밋되는 템플릿입니다.
# 실제 값을 채워서 사용하려면 이 파일을 복사해 ".env" 로 저장하세요:
#
#   Windows:  copy .env.example .env
#   macOS/Linux:  cp .env.example .env
#
# 그리고 ".env" 안의 각 KEY=VALUE 줄에 본인 키를 입력합니다.
# 서버는 부팅 시 .env 를 자동 로드합니다 (zero-deps, 내장 파서).
#
# 주의: .env 는 .gitignore 에 등록되어 있어 GitHub 에 올라가지 않습니다.
#       Render 같은 호스팅에서는 이 파일 대신 대시보드의 "Environment Variables"
#       메뉴에서 동일한 KEY=VALUE 를 등록하세요.
# ─────────────────────────────────────────────────

# ── 네이버 OpenAPI (뉴스 검색에 사용) ─────────────────────
# 발급: https://developers.naver.com/apps/#/register
#   → 애플리케이션 등록 → "검색" 사용 API 체크
#   → Client ID / Client Secret 복사해서 아래에 붙여넣기
# 미입력 시 /api/stock-news 는 기존 stock.naver.com 헤드라인 폴백 사용.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── DART OpenAPI (국민연금 매수/매도 표에 사용) ──────────
# 발급: https://opendart.fss.or.kr/uss/umt/cmm/EgovMberRegist.do
#   → 회원가입 → 인증키 신청 (즉시 발급, 40자)
# 일일 1만 호출 무료. 미입력 시 /api/pension-flows 비활성.
DART_API_KEY=

# ── 공공데이터포털 (data.go.kr) — 국민연금공단 기금 포트폴리오 ─
# 발급: https://www.data.go.kr → 로그인 → 활용신청 → 인증키 확인
# 일반적으로 'Encoding' 키 (URL-safe) 사용. 키 형식: 영숫자 + %2B, %2F 등 100자 안팎.
# 데이터셋 예: https://www.data.go.kr/data/15106894/fileData.do (기금 포트폴리오 현황)
# 미입력 시 해당 데이터 비활성. 다음 라운드에서 활용 예정.
DATA_GO_KR_SERVICE_KEY=

# ── Anthropic Claude API (뉴스 AI 요약 — 선택, 향후 라운드용) ──
# 발급: https://console.anthropic.com/settings/keys
# 미입력 시 AI 요약 기능 비활성.
ANTHROPIC_API_KEY=

# ── 텔레그램 봇 (기기 간 동기화 — 라운드 2 에서 도입, 선택) ──
# 발급: @BotFather 봇과 대화 → /newbot → 토큰 발급
# 미입력 시 동기화 모달이 "비활성" 상태로 표시.
TELEGRAM_BOT_TOKEN=

# ── 로컬 포트 (선택) ────────────────────────────────────
# 명시하지 않으면 4274, Render 환경에서는 PORT 자동 주입.
# PORT=4274
